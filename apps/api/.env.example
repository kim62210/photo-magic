ENV=development
APP_NAME=photo-magic-api
APP_VERSION=0.1.0

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/photo_magic
REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_UPLOADS=photo-magic-uploads
S3_BUCKET_EDITS=photo-magic-edits
S3_BUCKET_AI_CACHE=photo-magic-ai-cache

SENTRY_DSN=

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
